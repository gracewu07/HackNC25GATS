{
  "manifest_version": 3,
  "name": "Student Discount Alert",
  "version": "1.0",
  "description": "Alerts users of student discounts on the current site.",
  "permissions": ["activeTab", "notifications", "tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
