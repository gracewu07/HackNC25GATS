{
  "manifest_version": 3,
  "name": "Pocketed",
  "version": "1.0",
  "description": "Alerts students when discounts are available.",
  "icons": {
    "128": "PocketedLogo.png"
  },
  "permissions": ["tabs", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}

