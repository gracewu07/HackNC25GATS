{
  "manifest_version": 3,
  "name": "Pocketed",
  "version": "1.0",
  "description": "Popup will appear when student deals/discounts are available for the website.",
  "icons": {
    "128": "PocketedLogo.png"
  },
  "permissions": ["activeTab", "scripting", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "PocketedLogo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}

